{
  "name": "Heartbeat",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 30
            }
          ]
        }
      },
      "id": "hb-01",
      "name": "Every 30 Minutes",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [240, 300]
    },
    {
      "parameters": {
        "chatId": "={{ $env.TELEGRAM_CHAT_ID }}",
        "text": "={{ '✅ Heartbeat OK — ' + new Date().toISOString() }}",
        "additionalFields": {}
      },
      "credentials": {
        "telegramApi": {
          "id": "telegramBot",
          "name": "Telegram Bot"
        }
      },
      "id": "hb-02",
      "name": "Telegram Heartbeat",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [440, 300]
    }
  ],
  "connections": {
    "Every 30 Minutes": {
      "main": [
        [{"node": "Telegram Heartbeat", "type": "main", "index": 0}]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  },
  "versionId": "heartbeat-v1",
  "meta": {
    "instanceId": ""
  },
  "id": "heartbeat-01",
  "tags": []
}
