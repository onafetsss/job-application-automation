{
  "name": "JobSpy Scrape",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 4
            }
          ]
        }
      },
      "id": "js-01",
      "name": "Every 4 Hours",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [240, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://job-app-api:8000/scrape/scrape-jobspy",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "contentType": "json",
        "bodyParameters": {
          "parameters": [
            {
              "name": "search_term",
              "value": "Product Manager"
            },
            {
              "name": "location",
              "value": "Remote"
            },
            {
              "name": "results_wanted",
              "value": "50"
            },
            {
              "name": "hours_old",
              "value": "24"
            },
            {
              "name": "site_names",
              "value": "=[\"indeed\"]"
            }
          ]
        },
        "options": {}
      },
      "credentials": {
        "httpHeaderAuth": {
          "id": "fastApiKey",
          "name": "FastAPI Key"
        }
      },
      "id": "js-02",
      "name": "Scrape JobSpy",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [440, 300],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "js-cond-1",
              "leftValue": "={{ $json.warning }}",
              "rightValue": "zero_results_possible_block",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "js-03",
      "name": "Zero Results Warning?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [640, 300]
    },
    {
      "parameters": {
        "fieldToSplitOut": "jobs",
        "options": {}
      },
      "id": "js-04",
      "name": "Split Jobs",
      "type": "n8n-nodes-base.splitOut",
      "typeVersion": 1,
      "position": [840, 380]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://job-app-api:8000/ingest/ingest-lead",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "contentType": "json",
        "bodyParameters": {
          "parameters": [
            {
              "name": "title",
              "value": "={{ $json.title }}"
            },
            {
              "name": "company",
              "value": "={{ $json.company }}"
            },
            {
              "name": "location",
              "value": "={{ $json.location }}"
            },
            {
              "name": "url",
              "value": "={{ $json.job_url }}"
            },
            {
              "name": "source",
              "value": "indeed"
            },
            {
              "name": "clean_jd",
              "value": "={{ $json.description }}"
            }
          ]
        },
        "options": {}
      },
      "credentials": {
        "httpHeaderAuth": {
          "id": "fastApiKey",
          "name": "FastAPI Key"
        }
      },
      "id": "js-05",
      "name": "Ingest Lead",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1040, 380],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "chatId": "={{ $env.TELEGRAM_CHAT_ID }}",
        "text": "={{ '⚠️ JobSpy: ' + ($json.warning === 'zero_results_possible_block' ? 'Zero results — possible IP block' : ('Error: ' + ($json.error?.message || JSON.stringify($json)))) }}",
        "additionalFields": {}
      },
      "credentials": {
        "telegramApi": {
          "id": "telegramBot",
          "name": "Telegram Bot"
        }
      },
      "id": "js-06",
      "name": "Telegram Alert",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [840, 220]
    }
  ],
  "connections": {
    "Every 4 Hours": {
      "main": [
        [{"node": "Scrape JobSpy", "type": "main", "index": 0}]
      ]
    },
    "Scrape JobSpy": {
      "main": [
        [{"node": "Zero Results Warning?", "type": "main", "index": 0}],
        [{"node": "Telegram Alert", "type": "main", "index": 0}]
      ]
    },
    "Zero Results Warning?": {
      "main": [
        [{"node": "Telegram Alert", "type": "main", "index": 0}],
        [{"node": "Split Jobs", "type": "main", "index": 0}]
      ]
    },
    "Split Jobs": {
      "main": [
        [{"node": "Ingest Lead", "type": "main", "index": 0}]
      ]
    },
    "Ingest Lead": {
      "main": [
        [],
        [{"node": "Telegram Alert", "type": "main", "index": 0}]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  },
  "versionId": "jobspy-scrape-v1",
  "meta": {
    "instanceId": ""
  },
  "id": "jobspy-scrape-01",
  "tags": []
}
